{
  "name": "@betterdb/agent-memory",
  "version": "0.6.1",
  "description": "Standalone agent memory: agent-cache short-term tiers plus a semantic long-term MemoryStore over valkey-search",
  "keywords": [
    "valkey",
    "redis",
    "valkey-search",
    "agent",
    "memory",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BetterDB-inc/monitor",
    "directory": "packages/agent-memory"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/inject-telemetry-defaults.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@betterdb/agent-cache": "workspace:*",
    "@betterdb/valkey-search-kit": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "posthog-node": ">=4.0.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@types/node": "^22.19.15",
    "iovalkey": ">=0.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
