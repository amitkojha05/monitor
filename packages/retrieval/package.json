{
  "name": "@betterdb/retrieval",
  "version": "0.1.0",
  "description": "Developer-facing retrieval SDK over valkey-search: index lifecycle, upsert, vector + filtered query",
  "keywords": [
    "valkey",
    "redis",
    "valkey-search",
    "vector-search",
    "retrieval"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BetterDB-inc/monitor",
    "directory": "packages/retrieval"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/inject-telemetry-defaults.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:longmemeval": "tsx eval/longmemeval/run.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@betterdb/valkey-search-kit": "workspace:*",
    "posthog-node": ">=4.0.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "iovalkey": "^0.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
